# 1. Telegram Bot Token (Lấy từ @BotFather trên Telegram)
BOT_TOKEN="nhap_token_bot_cua_ban_vao_day"

# 2. OpenAI API Key (Lấy từ platform.openai.com)
OPENAI_API_KEY="sk-nhap_key_openai_cua_ban_vao_day"

# 3. Database URL (PostgreSQL) 
# Chú ý: URL này đã được setup khớp với docker-compose.yml
DATABASE_URL="postgresql://frameon:frameon_password@localhost:5432/frameon_db?schema=public"

# 4. Redis URL (Dùng cho BullMQ xử lý hàng đợi)
# URL này cũng đã khớp với docker-compose.yml
REDIS_URL="redis://localhost:6379"
